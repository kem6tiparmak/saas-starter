# ============================================================================
#  B2B-SaaS Template — Environment-Variablen
#  Kopiere diese Datei zu `.env` und fuelle die Werte. `.env` ist gitignored.
# ============================================================================

# --- Datenbank (Postgres: Supabase / Neon / Vercel Postgres) ---
# DATABASE_URL: gepoolte Verbindung (PgBouncer) — fuer normale Queries.
# DIRECT_DATABASE_URL: direkte/unpooled Verbindung — fuer `prisma migrate deploy`.
# Beide findest du im DB-Dashboard unter "Connection string" (Pooled vs. Direct).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Zufalls-Secret zum Signieren der JWT-Sessions.
# Generieren mit: npx auth secret   (oder: openssl rand -base64 33)
AUTH_SECRET=""

# --- Claude API (Anthropic) ---
# Dedizierter API-Key NUR fuer dieses Projekt. WICHTIG: in der Anthropic Console
# ein Workspace-Spend-Limit setzen, BEVOR der Key benutzt wird (harte Kostenbremse).
# Console -> Settings -> Limits. Key unter: Console -> API keys.
ANTHROPIC_API_KEY=""

# --- E-Mail (Nodemailer / Gmail SMTP) ---
# Einfachster Start: Gmail mit App-Passwort. Fuer Volumen spaeter auf Resend/Postmark
# wechseln (email.ts anpassen).
# GMAIL_USER: die Gmail-Adresse, von der gesendet wird.
# GMAIL_APP_PASSWORD: App-Passwort (NICHT das Login-PW). Erstellen unter
#   Google-Konto -> Sicherheit -> 2-Faktor aktiv -> App-Passwoerter.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# --- Stripe (Billing / Abos) ---
# WICHTIG: einen Restricted Key (rk_) mit minimalen Rechten verwenden, NICHT den
# vollen Secret Key. Nur server-seitig, niemals NEXT_PUBLIC_. Test-Keys fuer Test,
# Live-Keys fuer Live.
# Stripe-Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=""
# Signing-Secret des Webhook-Endpoints (whsec_...). Entsteht beim Anlegen des
# Endpoints unter Developers -> Webhooks, oder lokal via:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""
# Price-ID des Abos (price_..., wiederkehrend/monatlich).
# Stripe-Dashboard -> Produkt anlegen -> Preis -> ID kopieren.
STRIPE_PRICE_PRO=""

# --- Oeffentliche App-URL ---
# Volle Produktions-URL ohne abschliessenden Slash, z. B. https://meinprojekt.app
# Wird fuer Stripe-Checkout-Redirects, Metadaten und Links genutzt.
# Fallback im Code: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Kostenschutz ---
# Fallback-Monatslimit fuer KI-Aktionen, falls eine Org (wider Erwarten) kein
# eigenes Limit in der DB hat. Das echte Plan-Limit steht pro Org in der DB
# (monthlyActionLimit), vom Stripe-Webhook gepflegt.
MONTHLY_ACTION_LIMIT="10"

# --- Sentry (Error Monitoring) — optional ---
# Ohne diese Werte laeuft die App; es wird nur kein Monitoring aktiv.
# NEXT_PUBLIC_SENTRY_DSN / SENTRY_DSN: gleicher DSN-Wert. Ein DSN erlaubt nur das
# Senden von Events (kein Lesen), daher im Client unkritisch.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Fuer Source-Map-Upload zur Build-Zeit (Vercel: als Build-Env setzen, nicht Runtime).
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
